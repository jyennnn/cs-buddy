{
  "name": "cs-buddy",
  "version": "0.0.1",
  "description": "your customer success buddy",
  "author": {
    "name": "jyen",
    "email": "",
    "url": ""
  },
  "license": "MIT",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "bedframe dev",
    "build": "tsc && bedframe build",
    "release": "gh release create $npm_package_name@$npm_package_version ./dist/*.zip --generate-notes",
    "publish": "bedframe publish -b",
    "format": "prettier --write .",
    "lint": "oxlint --fix .",
    "fix": "pnpm run format && pnpm run lint",
    "test": "vitest run --coverage",
    "commit": "lint-staged && cz",
    "zip": "bedframe zip",
    "convert:safari": "xcrun safari-web-extension-converter dist/safari --project-location . --app-name $npm_package_name-safari"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "clsx": "^2.1.1",
    "react-icons": "^5.5.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@bedframe/cli": "^0.0.95",
    "@bedframe/core": "^0.0.46",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "happy-dom": "^18.0.1",
    "vitest": "^3.2.4",
    "@vitest/coverage-istanbul": "^3.2.4",
    "@types/node": "^24.6.2",
    "@types/chrome": "^0.0.326",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "oxlint": "^1.2.0",
    "globals": "^16.2.0",
    "lint-staged": "^16.1.2",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "lefthook": "^1.11.14",
    "@tailwindcss/vite": "^4.1.10",
    "@tailwindcss/postcss": "^4.1.10",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.8.3",
    "unplugin-fonts": "^1.3.1",
    "vite": "^6.3.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix"
    ],
    "*.{css,html,json}": "prettier --write"
  },
  "prettier": {
    "tabWidth": 2,
    "semi": false,
    "singleQuote": true,
    "tailwindFunctions": [
      "clsx"
    ],
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
